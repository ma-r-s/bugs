{
  "name": "bugs",
  "version": "1.0.0",
  "description": "A field guide to twelve famous software bugs, illustrated and explained.",
  "keywords": [
    "sveltekit",
    "svelte",
    "software-bugs",
    "field-guide",
    "computing-history"
  ],
  "author": "Mario A. Ruiz <marioalejandroruizsarmiento@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ma-r-s/bugs.git"
  },
  "homepage": "https://bugs.ma-r-s.com",
  "bugs": "https://github.com/ma-r-s/bugs/issues",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
